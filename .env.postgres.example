# Пример для PostgreSQL (docker compose up -d)
DATABASE_URL="postgresql://users:users@localhost:5432/users?schema=public"
PORT=3000
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=12

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_FULL_NAME=Админ Системный
RESERVED_ADMIN_EMAILS=
