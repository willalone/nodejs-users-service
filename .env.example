PORT=3000
DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=12

# Учётка админа для seed (npm run db:seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_FULL_NAME=Админ Системный

# Доп. email, запрещённые для регистрации (через запятую)
RESERVED_ADMIN_EMAILS=
